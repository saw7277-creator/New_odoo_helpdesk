<odoo>
    <record id="action_helpdesk_overview" model="ir.actions.act_window">
        <field name="name">Overview</field><field name="res_model">helpdesk.team</field><field name="view_mode">kanban,list,form</field>
    </record>
    <record id="action_helpdesk_ticket_all" model="ir.actions.act_window">
        <field name="name">All Tickets</field><field name="res_model">helpdesk.ticket</field><field name="view_mode">list,kanban,activity,pivot,form</field>
    </record>
    <record id="action_helpdesk_ticket_my" model="ir.actions.act_window">
        <field name="name">My Tickets</field><field name="res_model">helpdesk.ticket</field><field name="view_mode">list,kanban,activity,pivot,form</field><field name="domain">[('user_id', '=', uid)]</field>
    </record>
    <record id="action_helpdesk_team" model="ir.actions.act_window">
        <field name="name">Helpdesk Teams</field><field name="res_model">helpdesk.team</field><field name="view_mode">list,form</field>
    </record>
    <record id="action_helpdesk_stage" model="ir.actions.act_window">
        <field name="name">Stages</field><field name="res_model">helpdesk.stage</field><field name="view_mode">list,form</field>
    </record>
    <record id="action_helpdesk_sla" model="ir.actions.act_window">
        <field name="name">SLA Policies</field><field name="res_model">helpdesk.sla.policy</field><field name="view_mode">list,form</field>
    </record>
    <record id="action_helpdesk_tag" model="ir.actions.act_window">
        <field name="name">Tags</field><field name="res_model">helpdesk.tag</field><field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_helpdesk_root" name="Helpdesk" sequence="10" groups="new_helpdesk.group_helpdesk_user"/>
    <menuitem id="menu_helpdesk_overview" name="Overview" parent="menu_helpdesk_root" action="action_helpdesk_overview" sequence="10"/>
    <menuitem id="menu_helpdesk_tickets" name="Tickets" parent="menu_helpdesk_root" sequence="20"/>
    <menuitem id="menu_helpdesk_tickets_my" name="My Tickets" parent="menu_helpdesk_tickets" action="action_helpdesk_ticket_my" sequence="10"/>
    <menuitem id="menu_helpdesk_tickets_all" name="All Tickets" parent="menu_helpdesk_tickets" action="action_helpdesk_ticket_all" sequence="20"/>
    <menuitem id="menu_helpdesk_reporting" name="Reporting" parent="menu_helpdesk_root" sequence="30"/>
    <menuitem id="menu_helpdesk_reporting_ticket_analysis" name="Tickets Analysis" parent="menu_helpdesk_reporting" action="action_helpdesk_ticket_all" sequence="10"/>
    <menuitem id="menu_helpdesk_configuration" name="Configuration" parent="menu_helpdesk_root" sequence="40"/>
    <menuitem id="menu_helpdesk_configuration_team" name="Helpdesk Teams" parent="menu_helpdesk_configuration" action="action_helpdesk_team" sequence="10"/>
    <menuitem id="menu_helpdesk_configuration_stage" name="Stages" parent="menu_helpdesk_configuration" action="action_helpdesk_stage" sequence="20"/>
    <menuitem id="menu_helpdesk_configuration_sla" name="SLA Policies" parent="menu_helpdesk_configuration" action="action_helpdesk_sla" sequence="30"/>
    <menuitem id="menu_helpdesk_configuration_tag" name="Tags" parent="menu_helpdesk_configuration" action="action_helpdesk_tag" sequence="40"/>
</odoo>
